{
  "name": "gaussian-splat-viewer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\" \"#node_modules\"",
    "format": "prettier --write \"src/**/*.{ts,css}\" \"*.html\"",
    "format:check": "prettier --check \"src/**/*.{ts,css}\" \"*.html\""
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.69",
    "markdownlint-cli2": "^0.21.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
}
